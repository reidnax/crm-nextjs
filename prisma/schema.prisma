// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  name        String?
  role        String?
  phone       String?
  email       String    @unique
  website     String?
  active      Boolean   @default(true)
  // Enhanced profile fields (non-breaking)
  avatar      String? // Profile picture URL
  department  String? // User department
  jobTitle    String? // Job title/position
  bio         String? // Short biography
  timezone    String? // User timezone
  lastLoginAt DateTime? // Last login timestamp
  preferences Json? // User preferences/settings
  // RBAC fields (non-breaking)
  managerId   Int? // Manager relationship for hierarchy
  createdAt   DateTime  @default(now()) @map("createdAt")
  updatedAt   DateTime  @updatedAt @map("updatedAt")

  // Relations
  createdLeads    Lead[]    @relation("UserCreatedLeads")
  assignedLeads   Lead[]    @relation("UserAssignedLeads")
  createdMeetings Meeting[] @relation("UserCreatedMeetings")
  deletedMeetings Meeting[] @relation("UserDeletedMeetings")
  createdTasks    Task[]    @relation("UserCreatedTasks")
  assignedTasks   Task[]    @relation("UserAssignedTasks")
  deletedTasks    Task[]    @relation("UserDeletedTasks")
  createdNotes    Note[]    @relation("UserCreatedNotes")

  // RBAC relations
  manager         User?                 @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates    User[]                @relation("UserManager")
  userPermissions UserPermission[]
  auditLogs       PermissionAuditLog[]  @relation("AuditUser")
  grantedAudits   PermissionAuditLog[]  @relation("AuditGrantedBy")
  ownedResources  ResourceOwnership[]
  migrationLogs   MigrationLog[]        @relation("UserMigrationLogs")
  dailyReports    DailyActivityReport[] @relation("UserDailyReports")
  kpiGoals        KpiGoal[]             @relation("UserKpiGoals")
  kpiActionItems  KpiActionItem[]       @relation("UserKpiActionItems")

  @@map("Users")
}

model Lead {
  id               Int       @id @default(autoincrement())
  name             String
  email            String?   @unique
  phone            String?
  alternatePhone   String?
  company          String?
  businessCategory String?
  businessIndustry String?
  status           String?
  subStatus        String?
  convertedStatus  String?
  state            String?
  address          String?
  pincode          String?
  annualRevenue    Decimal?
  investmentLimit  Decimal?
  designation      String?
  city             String?
  description      String?
  website          String?
  dealer           Json?
  createdBy        Int?
  assign           Int?
  // Enhanced lead fields (non-breaking)
  priority         String?   @default("Medium") // High, Medium, Low
  source           String? // Lead source (Website, Referral, etc.)
  tags             String[] // Tags for categorization
  socialMedia      Json? // Social media links
  lastContactDate  DateTime? // Last contact with lead
  nextFollowUpDate DateTime? // Next planned follow-up
  leadScore        Int?      @default(0) // Lead scoring
  isArchived       Boolean   @default(false) // Soft delete
  customFields     Json? // Custom data fields
  createdAt        DateTime  @default(now()) @map("createdAt")
  updatedAt        DateTime  @updatedAt @map("updatedAt")

  // Relations
  creator  User?     @relation("UserCreatedLeads", fields: [createdBy], references: [id], onDelete: SetNull)
  assignee User?     @relation("UserAssignedLeads", fields: [assign], references: [id], onDelete: SetNull)
  meetings Meeting[]
  tasks    Task[]
  notes    Note[]

  @@index([status])
  @@index([priority])
  @@index([assign])
  @@index([createdAt])
  @@index([name]) // For search functionality
  @@map("Leads")
}

model Meeting {
  id           Int       @id @default(autoincrement())
  subject      String
  description  String?
  duration     Int
  startTime    DateTime
  endTime      DateTime
  leadId       Int
  createdBy    Int?
  // Enhanced meeting fields (non-breaking)
  status       String?   @default("Scheduled") // Scheduled, In Progress, Completed, Cancelled
  type         String?   @default("Meeting") // Meeting, Call, Video Call, etc.
  location     String? // Meeting location or URL
  agenda       String? // Meeting agenda
  outcome      String? // Meeting outcome/result
  priority     String?   @default("Medium") // High, Medium, Low
  attendees    Json? // List of attendees
  isRecurring  Boolean   @default(false) // Recurring meeting flag
  parentId     Int? // For recurring meetings
  reminderSent Boolean   @default(false) // Reminder notification status
  // Soft delete fields
  deletedAt    DateTime?
  deletedBy    Int?
  createdAt    DateTime  @default(now()) @map("createdAt")
  updatedAt    DateTime  @updatedAt @map("updatedAt")

  // Relations
  lead          Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator       User? @relation("UserCreatedMeetings", fields: [createdBy], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("UserDeletedMeetings", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@index([startTime])
  @@index([status])
  @@index([leadId])
  @@index([deletedAt])
  @@map("Meetings")
}

model Task {
  id             Int       @id @default(autoincrement())
  subject        String
  description    String?
  dueDate        DateTime
  leadId         Int
  createdBy      Int?
  // Enhanced task fields (non-breaking)
  status         String?   @default("Pending") // Pending, In Progress, Completed, Cancelled
  priority       String?   @default("Medium") // High, Medium, Low
  category       String? // Task category (Follow-up, Demo, etc.)
  estimatedHours Float? // Estimated hours to complete
  actualHours    Float? // Actual hours spent
  completedAt    DateTime? // Task completion timestamp
  tags           String[] // Task tags
  isRecurring    Boolean   @default(false) // Recurring task flag
  parentId       Int? // For recurring tasks
  assignedTo     Int? // Task can be assigned to different user
  reminderDate   DateTime? // Reminder date
  // Soft delete fields
  deletedAt      DateTime?
  deletedBy      Int?
  createdAt      DateTime  @default(now()) @map("createdAt")
  updatedAt      DateTime  @updatedAt @map("updatedAt")

  // Relations
  lead          Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator       User? @relation("UserCreatedTasks", fields: [createdBy], references: [id], onDelete: SetNull)
  assignee      User? @relation("UserAssignedTasks", fields: [assignedTo], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("UserDeletedTasks", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@index([dueDate])
  @@index([status])
  @@index([priority])
  @@index([leadId])
  @@index([assignedTo])
  @@index([createdBy])
  @@index([completedAt])
  @@index([category])
  @@index([deletedAt])
  // Text search indexes
  @@index([subject])
  // Composite indexes for common query patterns
  @@index([status, dueDate])
  @@index([leadId, status])
  @@index([assignedTo, status])
  @@index([createdBy, status])
  @@index([status, dueDate, leadId]) // For overdue queries
  @@index([status, priority]) // For filtered listings
  @@index([category, status]) // For category filtering
  @@map("Tasks")
}

model Note {
  id          Int      @id @default(autoincrement())
  subject     String
  description String
  leadId      Int
  createdBy   Int?
  // Enhanced note fields (non-breaking)
  type        String?  @default("General") // General, Call Log, Meeting Summary, etc.
  category    String? // Note category
  tags        String[] // Note tags
  isPrivate   Boolean  @default(false) // Private note visibility
  isPinned    Boolean  @default(false) // Pin important notes
  attachments Json? // File attachments metadata
  mentions    String[] // User mentions in note
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  // Relations
  lead    Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator User? @relation("UserCreatedNotes", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([type])
  @@index([isPinned])
  @@map("Notes")
}

// RBAC System Tables
model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., 'leads.create', 'users.read.all'
  description String?
  category    String? // e.g., 'leads', 'users', 'reports'
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  // Relations
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([category])
  @@map("Permissions")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  role         String // e.g., 'Admin', 'Manager', 'Assignee'
  permissionId Int
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  // Relations
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("RolePermissions")
}

model UserPermission {
  id           Int      @id @default(autoincrement())
  userId       Int
  permissionId Int
  granted      Boolean  @default(true) // true = granted, false = explicitly denied
  grantedBy    Int? // Who granted this permission
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("UserPermissions")
}

model PermissionAuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int // User whose permissions changed
  action     String // 'granted', 'revoked', 'role_changed'
  permission String? // Permission name (null for role changes)
  oldValue   Json? // Previous value
  newValue   Json? // New value
  changedBy  Int? // Who made the change
  ipAddress  String? // IP address of the change
  userAgent  String? // User agent string
  createdAt  DateTime @default(now()) @map("createdAt")

  // Relations
  user          User  @relation("AuditUser", fields: [userId], references: [id], onDelete: Cascade)
  changedByUser User? @relation("AuditGrantedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("PermissionAuditLogs")
}

model ResourceOwnership {
  id           Int      @id @default(autoincrement())
  resourceType String // 'lead', 'task', 'meeting', 'note'
  resourceId   Int // ID of the resource
  ownerId      Int // Owner user ID
  createdAt    DateTime @default(now()) @map("createdAt")

  // Relations
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@index([ownerId])
  @@map("ResourceOwnerships")
}

model MigrationLog {
  id             Int      @id @default(autoincrement())
  action         String // 'deploy', 'deploy-selective', 'deploy-to-production', 'status', 'generate', 'reset'
  description    String // Human-readable description
  command        String // Actual command executed
  migrationName  String? // Specific migration name (for selective deployments)
  targetDatabase String? // Target database URL (for production deployments)
  output         String? // Command output
  error          String? // Error output (if any)
  success        Boolean // Whether the operation was successful
  duration       Int // Execution time in milliseconds
  executedBy     Int // User who executed the migration
  executedAt     DateTime @default(now()) @map("createdAt")

  // Relations
  user User @relation("UserMigrationLogs", fields: [executedBy], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([executedBy])
  @@index([executedAt])
  @@index([success])
  @@map("MigrationLogs")
}

// KPI Module
model KpiDepartment {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goals KpiGoal[]

  @@map("KpiDepartments")
}

// Hierarchical KPI goal node: Yearly → Quarterly → Monthly → Daily
model KpiGoal {
  id             Int      @id @default(autoincrement())
  departmentId   Int
  parentId       Int?     // null = yearly top-level
  level          String   // "yearly" | "quarterly" | "monthly" | "daily"
  name           String
  unit           String?  // "%", "Cr", "units", etc.
  periodLabel    String   // "2026" | "Q1-2026" | "2026-06" | "2026-06-20"
  target         String?
  actual         String?
  actualNumeric  Decimal? @db.Decimal(18, 4)
  status         String?  // "green" | "yellow" | "red"
  higherIsBetter Boolean  @default(true)
  notes          String?
  sortOrder      Int      @default(0)
  enteredBy      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department    KpiDepartment   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  parent        KpiGoal?        @relation("GoalChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children      KpiGoal[]       @relation("GoalChildren")
  actionItems   KpiActionItem[]
  enteredByUser User            @relation("UserKpiGoals", fields: [enteredBy], references: [id], onDelete: Cascade)

  @@index([departmentId, level, periodLabel])
  @@index([parentId])
  @@map("KpiGoals")
}

// Action items attached to any KpiGoal node at any level
model KpiActionItem {
  id          Int       @id @default(autoincrement())
  goalId      Int
  title       String
  description String?
  target      String?
  actual      String?
  owner       String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("open") // "open"|"in-progress"|"done"|"blocked"
  notes       String?
  createdBy   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  goal          KpiGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("UserKpiActionItems", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("KpiActionItems")
}

// Daily Activity Reports System
model DailyActivityReport {
  id                       String   @id @default(cuid())
  // Report date - the business date this report is for (default today in UI)
  reportDate               DateTime
  // Executive submitting the report - references User.id
  executiveId              Int
  // Zone/state where executive operates - picklist value stored as single string
  zone                     String
  // Sales units sold today - non-negative integer
  salesUnitsToday          Int
  // Collections amount in INR today - non-negative decimal with 2 decimal precision
  collectionsTodayINR      Decimal  @db.Decimal(14, 2)
  // Number of dealer meetings conducted today
  dealerMeetingsCount      Int
  // Number of plant visits conducted today
  plantVisitsCount         Int
  // Number of new dealership visits conducted today
  newDealershipVisitsCount Int
  // Optional notes/comments for the day
  notes                    String?

  // System computed fields - set server-side on create
  // Month key for efficient querying - format "YYYY-MM"
  monthKey         String
  // Timestamp when report was submitted to system
  submittedAt      DateTime @default(now())
  // User ID who submitted the report (from session)
  submittedBy      Int
  // Whether this submission was after 21:00 IST cutoff for the report date
  isLateSubmission Boolean
  // Geographic location data captured from client device
  geoCity          String?
  geoLat           Decimal? @db.Decimal(10, 7)
  geoLon           Decimal? @db.Decimal(10, 7)

  // Relations
  executive User @relation("UserDailyReports", fields: [executiveId], references: [id], onDelete: Cascade)

  // Constraints to ensure one report per executive per date
  @@unique([executiveId, reportDate])
  // Indexes for efficient querying
  @@index([monthKey])
  @@index([executiveId, monthKey])
  @@index([zone])
  @@index([reportDate])
  @@map("DailyActivityReports")
}
